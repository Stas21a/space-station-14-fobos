<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc 'admin-player-actions-window-ert'}"
               MinWidth="980"
               MinHeight="760">
    <BoxContainer Orientation="Vertical" SeparationOverride="12" Margin="12">
        <PanelContainer StyleClasses="panel">
            <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="12">
                <Label Text="{Loc 'ert-admin-settings-title'}" StyleClasses="LabelHeading" />
                <BoxContainer Orientation="Horizontal" SeparationOverride="12">
                    <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4">
                        <Label Text="{Loc 'ert-admin-cooldown-label'}" />
                        <LineEdit Name="CooldownSeconds" />
                        <Button Name="SetCooldownButton" Text="{Loc 'ert-admin-apply-button'}" />
                    </BoxContainer>
                    <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4">
                        <Label Text="{Loc 'ert-admin-points-label'}" />
                        <LineEdit Name="PointsEdit" />
                        <Button Name="SetPointsButton" Text="{Loc 'ert-admin-apply-button'}" />
                    </BoxContainer>
                    <BoxContainer Orientation="Vertical" SeparationOverride="4" MinWidth="180">
                        <Label Text="{Loc 'ert-admin-actions-label'}" />
                        <Button Name="RefreshButton" Text="{Loc 'ert-admin-refresh-button'}" />
                    </BoxContainer>
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>

        <TabContainer Name="RequestsTabContainer" VerticalExpand="True">
            <PanelContainer StyleClasses="panel">
                <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="12">
                    <BoxContainer Orientation="Horizontal" SeparationOverride="12" VerticalExpand="True">
                        <ItemList Name="PendingRequestsList" MinSize="420 420" HorizontalExpand="True" VerticalExpand="True" />
                        <PanelContainer StyleClasses="panel" MinSize="300 420">
                            <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="12" VerticalExpand="True">
                                <Label Text="{Loc 'ert-admin-selected-requester'}" />
                                <Label Name="PendingRequesterLabel" StyleClasses="LabelSubText" />
                                <Label Text="{Loc 'ert-admin-selected-reason'}" Margin="0,8,0,0" />
                                <RichTextLabel Name="PendingReasonLabel" StyleClasses="LabelSubText" />
                                <Control VerticalExpand="True" />
                                <Button Name="RejectPendingButton" Text="{Loc 'ert-admin-reject-button'}" Margin="0,8,0,0" />
                                <Button Name="ApprovePendingManualButton" Text="{Loc 'ert-admin-approve-manual-button'}" />
                                <Button Name="ApprovePendingAutoButton" Text="{Loc 'ert-admin-approve-auto-button'}" />
                            </BoxContainer>
                        </PanelContainer>
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>

            <PanelContainer StyleClasses="panel">
                <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="12">
                    <BoxContainer Orientation="Horizontal" SeparationOverride="12" VerticalExpand="True">
                        <ItemList Name="ApprovedRequestsList" MinSize="420 420" HorizontalExpand="True" VerticalExpand="True" />
                        <PanelContainer StyleClasses="panel" MinSize="340 420">
                            <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="12" VerticalExpand="True">
                                <Label Text="{Loc 'ert-admin-selected-requester'}" />
                                <Label Name="ApprovedRequesterLabel" StyleClasses="LabelSubText" />

                                <Label Text="{Loc 'ert-admin-arrival-label'}" Margin="0,8,0,0" />
                                <LineEdit Name="ArrivalSeconds" />
                                <Button Name="SetArrivalButton" Text="{Loc 'ert-admin-apply-button'}" />

                                <Label Text="{Loc 'ert-admin-approved-reason-label'}" Margin="0,8,0,0" />
                                <LineEdit Name="ReasonEdit" />
                                <Button Name="SetReasonButton" Text="{Loc 'ert-admin-set-reason-button'}" />

                                <Label Text="{Loc 'ert-admin-approved-team-label'}" Margin="0,8,0,0" />
                                <ItemList Name="AutoSpawnTeamList" MinSize="0 120" VerticalExpand="True" />
                                <Button Name="ChangeApprovedTeamButton" Text="{Loc 'ert-admin-set-team-button'}" />

                                <Button Name="QueueAutoSpawnButton" Text="{Loc 'ert-admin-queue-auto-button'}" Margin="0,8,0,0" />
                                <Button Name="CancelApprovedAutoSpawnButton" Text="{Loc 'ert-admin-cancel-auto-button'}" />
                            </BoxContainer>
                        </PanelContainer>
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>

            <PanelContainer StyleClasses="panel">
                <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="12">
                    <BoxContainer Orientation="Horizontal" SeparationOverride="12" VerticalExpand="True">
                        <ItemList Name="ManualApprovedRequestsList" MinSize="420 420" HorizontalExpand="True" VerticalExpand="True" />
                        <PanelContainer StyleClasses="panel" MinSize="300 420">
                            <BoxContainer Orientation="Vertical" SeparationOverride="8" Margin="12" VerticalExpand="True">
                                <Label Text="{Loc 'ert-admin-selected-requester'}" />
                                <Label Name="ManualApprovedRequesterLabel" StyleClasses="LabelSubText" />
                                <Label Text="{Loc 'ert-admin-selected-reason'}" Margin="0,8,0,0" />
                                <RichTextLabel Name="ManualApprovedReasonLabel" StyleClasses="LabelSubText" />
                                <Control VerticalExpand="True" />
                                <Button Name="PromoteManualApprovedButton" Text="{Loc 'ert-admin-promote-manual-button'}" Margin="0,8,0,0" />
                            </BoxContainer>
                        </PanelContainer>
                    </BoxContainer>
                </BoxContainer>
            </PanelContainer>
        </TabContainer>
    </BoxContainer>
</DefaultWindow>
